{
  "name": "@outloud/eslint-config",
  "version": "2.1.3",
  "description": "ESLint config for Outloud projects.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/madebyoutloud/eslint-config.git"
  },
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepack": "is-ci || pnpm build",
    "release": "release-it",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run lint && pnpm run typecheck"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^15.5.12",
    "@nuxt/eslint-plugin": "^1.15.2",
    "@prettier/plugin-xml": "^3.4.2",
    "@release-it/conventional-changelog": "^7.0.2",
    "@types/node": "^20.19.37",
    "@unocss/eslint-config": "66.6.6",
    "eslint": "^10.0.3",
    "eslint-plugin-format": "^1.5.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-vue": "^10.8.0",
    "is-ci": "^4.1.0",
    "release-it": "^16.3.0",
    "tsdown": "^0.21.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vue-eslint-parser": "^10.4.0"
  },
  "dependencies": {
    "@antfu/install-pkg": "^1.1.0",
    "@clack/prompts": "^0.10.1",
    "@eslint-community/eslint-utils": "^4.9.1",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint-config-flat-gitignore": "^2.2.1",
    "eslint-flat-config-utils": "^3.0.2",
    "eslint-merge-processors": "^2.0.0",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-processor-vue-blocks": "^2.0.0",
    "globals": "^17.4.0",
    "local-pkg": "^1.1.2",
    "typescript-eslint": "^8.57.0"
  },
  "peerDependencies": {
    "@next/eslint-plugin-next": "^15.2",
    "@nuxt/eslint-plugin": "^1.15",
    "@prettier/plugin-xml": "^3.4",
    "@unocss/eslint-config": "^66.6",
    "eslint": "^10",
    "eslint-plugin-format": "^1.5",
    "eslint-plugin-react": "^7.37",
    "eslint-plugin-react-hooks": "^5.2",
    "eslint-plugin-vue": "^10.0",
    "vue-eslint-parser": "^10.1"
  },
  "peerDependenciesMeta": {
    "vue-eslint-parser": {
      "optional": true
    },
    "eslint-plugin-vue": {
      "optional": true
    },
    "@nuxt/eslint-plugin": {
      "optional": true
    },
    "eslint-plugin-format": {
      "optional": true
    },
    "@unocss/eslint-config": {
      "optional": true
    },
    "@prettier/plugin-xml": {
      "optional": true
    },
    "eslint-plugin-react": {
      "optional": true
    },
    "eslint-plugin-react-hooks": {
      "optional": true
    },
    "@next/eslint-plugin-next": {
      "optional": true
    }
  }
}
